{
  "name": "TenantDocument",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "document_name": {
      "type": "string",
      "description": "Custom document name entered by owner"
    },
    "document_url": {
      "type": "string",
      "description": "Uploaded photo/file URL"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "tenant_id",
    "document_name",
    "document_url"
  ]
}