{
  "name": "Floor",
  "type": "object",
  "properties": {
    "property_id": {
      "type": "string",
      "description": "Reference to Property"
    },
    "name": {
      "type": "string",
      "description": "Floor name e.g. Ground Floor"
    },
    "floor_number": {
      "type": "number",
      "description": "Floor number for ordering"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
